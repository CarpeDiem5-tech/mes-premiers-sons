{
  "expo": {
    "name": "Mes Premiers Sons",
    "slug": "mes-premiers-sons",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mes-premiers-sons",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
